{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@main/*": ["./electron/main/*"],
      "@ipc/*": ["./electron/ipc/*"],
      "@services/*": ["./electron/services/*"]
    }
  },
  "include": [
    "electron/**/*.ts",
    "electron/**/*.d.ts"
  ]
}
